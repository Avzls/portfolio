# Copy to .env and fill in. The app loads this file automatically on startup.

# --- Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=porto_user
DB_PASSWORD=change-me
DB_NAME=porto

# --- Auth ---
# Generate a long random string: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret

# --- Server ---
PORT=8081
UPLOAD_DIR=./uploads

# CORS. When the frontend is served from the same domain via Nginx (the VPS
# setup in deploy/), requests are same-origin, so this can stay as-is.
# If the frontend is on a different domain, set the exact origin here.
ALLOWED_ORIGIN=*
