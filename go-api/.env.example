# Copy this file to .env and adjust the values for your environment.
# Variables already set in the real environment take precedence over .env.

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=porto

# Auth - IMPORTANT: set a long, random secret in production
JWT_SECRET=change-me-to-a-long-random-secret

# Server
PORT=8080
UPLOAD_DIR=./uploads

# CORS - set to your frontend origin in production, e.g. https://yourdomain.com
# Use * only for local development.
ALLOWED_ORIGIN=*
