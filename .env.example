# ===== Root env for docker compose (production) =====
# Copy to .env and replace every value. Do NOT commit the real .env.

# --- Database ---
DB_ROOT_PASSWORD=change-me-strong-root-pass
DB_NAME=porto
DB_USER=porto_user
DB_PASSWORD=change-me-strong-user-pass

# --- API ---
# Generate a long random string, e.g. `openssl rand -base64 48`
JWT_SECRET=change-me-to-a-long-random-secret

# CORS: the exact origin of your deployed frontend (NOT "*" in production).
# Example: https://porto.yourdomain.com
ALLOWED_ORIGIN=https://your-frontend-domain.com

# --- Web (Next.js) ---
# Public base URL of the API as reached by the browser.
# Example: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=https://your-api-domain.com
